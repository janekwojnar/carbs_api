# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/virtualcandle"

# Public app URL (local)
APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Production example:
# APP_URL="https://virtualcandle.com"
# NEXTAUTH_URL="https://virtualcandle.com"

# Auth
NEXTAUTH_SECRET="replace-with-long-random-secret-min-32-chars"
ADMIN_EMAIL="admin@virtualcandle.com"
ADMIN_PASSWORD="change-me"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# PayU (sandbox defaults)
PAYU_CLIENT_ID="your-payu-client-id"
PAYU_CLIENT_SECRET="your-payu-client-secret"
PAYU_WEBHOOK_SECRET="your-payu-webhook-secret"
PAYU_AUTH_URL="https://secure.snd.payu.com/pl/standard/user/oauth/authorize"
PAYU_API_URL="https://secure.snd.payu.com/api/v2_1/orders"

# Optional anti-bot / analytics
TURNSTILE_SECRET_KEY="optional"
POSTHOG_API_KEY="optional"
POSTHOG_HOST="https://app.posthog.com"

# Optional map provider key (if you switch from OSM/Leaflet tiles)
MAPBOX_API_KEY="optional"
